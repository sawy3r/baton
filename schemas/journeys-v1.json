{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baton.sawy3r.net/schemas/journeys-v1.json",
  "title": "Baton Customer Journeys",
  "description": "The critical customer journeys artefact (Rule 10): an ordered, version-controlled, human-ratified set of end-to-end journeys. Walkthrough attestations are a separate record (attestations-v1).",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "journeys", "is_ratified"],
  "$defs": {
    "id_token": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
      "minLength": 1
    }
  },
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://baton.sawy3r.net/schemas/journeys-v1.json"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Artefact schema version for forward compatibility."
    },
    "created_at": { "type": "string", "description": "ISO 8601." },
    "updated_at": { "type": "string", "description": "ISO 8601." },
    "is_ratified": {
      "type": "boolean",
      "description": "True when a human has ratified the artefact. The Rule 10 gate fails closed unless this is true."
    },
    "ratified_at": { "type": "string", "description": "ISO 8601; present once ratified." },
    "ratified_by": { "type": "string", "description": "Who ratified the artefact." },
    "journeys": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "user_type", "outcome"],
        "properties": {
          "id": {
            "$ref": "#/$defs/id_token",
            "description": "Journey id, e.g. J01-onboard-new-user."
          },
          "user_type": {
            "type": "string",
            "minLength": 1,
            "description": "The user type taking this journey."
          },
          "outcome": {
            "type": "string",
            "minLength": 1,
            "description": "The outcome the journey achieves."
          },
          "entry_surface": {
            "type": "string",
            "description": "Where the journey begins (route, command, screen)."
          },
          "has_regression": {
            "type": "boolean",
            "description": "True when an automated regression guards this journey."
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["order", "description"],
              "properties": {
                "order": { "type": "integer", "minimum": 0 },
                "description": { "type": "string", "minLength": 1 },
                "surface": {
                  "type": "string",
                  "description": "The surface this step acts on."
                }
              }
            }
          }
        }
      }
    }
  }
}
