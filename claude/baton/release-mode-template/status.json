{
  "$schema": "https://baton.sawy3r.net/schemas/slice-status-v1.json",
  "slice_id": "<slice-id>",
  "release": "<release-name>",
  "track": "<track-id, e.g. T1-identity-account — set by planner>",
  "covers_needs": [],
  "state": "planned",
  "owner": "human",
  "last_updated_by": "<agent-or-human-identifier>",
  "last_updated_at": "<ISO-8601 timestamp>",
  "start_commit": null,
  "spec_path": "docs/release/<release-name>/<slice-id>/spec.json",
  "proof_path": "docs/release/<release-name>/<slice-id>/proof.json",
  "journal_path": "docs/release/<release-name>/<slice-id>/journal.md",
  "planned_files": [],
  "actual_files": [],
  "test_commands": [],
  "reachability_artifacts": [],
  "open_deferrals": [],
  "verification": {
    "result": "pending",
    "verifier_session_id": null,
    "verifier_verdict_at": null,
    "verifier_was_fresh_context": null,
    "violations": []
  }
}
